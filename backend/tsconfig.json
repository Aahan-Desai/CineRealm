{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["esnext"],
    "types": ["node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src", "*.ts", "prisma/**/*.ts"],
  
}